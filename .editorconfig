
################################################################################
#                                                                              #
#                             Read more about it at                            #
#                           https://EditorConfig.org                           #
#                                                                              #
################################################################################


root = true


[*.{toml,yml,txt,py,sh,md}]
insert_final_newline = false
indent_style = space
end_of_line = lf
indent_size = 4
charset = utf-8

[*.{toml,yml,txt,py,sh,txt}]
trim_trailing_whitespace = true

[*.{md}]
trim_trailing_whitespace = false