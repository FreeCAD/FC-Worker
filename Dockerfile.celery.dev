FROM amrit3701/freecad-cli:1.0.2-amd64-ubuntu22.04-py3.11-qt5

# Set working directory
WORKDIR /app

# bubblewrap (and its util-linux companion `prlimit`) are required by
# fc_worker.sandbox to run RUN_CODE_SNIPPET.
RUN apt-get update && \
    apt-get install -y --no-install-recommends bubblewrap util-linux ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Copy requirements.txt
COPY requirements/main.txt requirements.txt

# Install dependencies
RUN pip3 install -r requirements.txt
RUN pip3 install watchdog

# Start Celery worker
CMD ["watchmedo", "auto-restart", "--directory", ".", "--pattern", "*.py", "--recursive", "--", "celery", "-A", "main.celery", "worker", "--loglevel", "info"]
